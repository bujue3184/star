generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model GameSession {
  id           String    @id @default(cuid())
  name         String
  createdAt    DateTime  @default(now())
  endedAt      DateTime?
  globalRule   String
  status       String    @default("WAITING")
  winnerBotId  String?
  maxRounds    Int
  currentRound Int       @default(0)
  participants GameBot[]
  rounds       Round[]
}

model GameBot {
  id             String      @id @default(cuid())
  sessionId      String
  name           String
  model          String
  basePrompt     String?
  apiKey         String?
  baseURL        String?
  order          Int
  finalScore     Int         @default(0)
  skillSnapshots String      @default("[]")
  session        GameSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  messages       Message[]
}

model Round {
  id          String      @id @default(cuid())
  sessionId   String
  roundNumber Int
  startedAt   DateTime    @default(now())
  finishedAt  DateTime?
  messages    Message[]
  session     GameSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

model Message {
  id            String   @id @default(cuid())
  roundId       String
  gameBotId     String?
  content       String
  skillSnapshot String   @default("{}")
  role          String   @default("assistant")
  createdAt     DateTime @default(now())
  gameBot       GameBot? @relation(fields: [gameBotId], references: [id])
  round         Round    @relation(fields: [roundId], references: [id], onDelete: Cascade)
}

model Skill {
  id          String   @id @default(cuid())
  name        String
  description String?
  type        String   @default("ROLE_PLAY")
  content     String
  author      String?
  version     String   @default("1.0.0")
  preview     String?
  tags        String   @default("[]")
  isPublic    Boolean  @default(true)
  downloads   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
